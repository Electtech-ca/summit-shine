# Pooled connection (used by the app at runtime). With Supabase, use the
# "Transaction pooler" connection string (port 6543).
DATABASE_URL=
# Direct, non-pooled connection (used only for `prisma migrate deploy`).
# With Supabase, use the "Direct connection" string (port 5432) — migrations
# hang indefinitely through the transaction pooler, since it doesn't support
# the advisory locks Prisma Migrate needs.
DIRECT_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_SITE_URL=
CRON_SECRET=
